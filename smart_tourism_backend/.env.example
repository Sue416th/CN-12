# ============================================================
# 智慧文旅平台 - 环境配置
# ============================================================

# ==================== LLM Configuration ====================
# LLM Provider: glm (智谱), openai, qwen (阿里)
LLM_PROVIDER=glm
LLM_API_KEY=your_glm_api_key_here
LLM_MODEL=glm-4

# 可选：使用OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4

# 可选：使用阿里Qwen
# LLM_PROVIDER=qwen
# LLM_API_KEY=your_qwen_api_key
# LLM_MODEL=qwen-turbo

# ==================== Knowledge Graph (Neo4j) ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ==================== Vector Database (Milvus) ====================
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ==================== External APIs ====================
# 和风天气API
QWEATHER_API_KEY=your_qweather_api_key
QWEATHER_API_HOST=https://devapi.qweather.com

# 高德地图API
AMAP_API_KEY=your_amap_api_key

# ==================== Database ====================
DATABASE_URL=sqlite:///./tourism.db
